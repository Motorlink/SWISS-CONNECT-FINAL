# =============================================================================
# SWISS-CONNECT Environment Variables
# =============================================================================
# cp .env.example .env

# -----------------------------------------------------------------------------
# ENVIRONMENT
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# POSTGRESQL
# -----------------------------------------------------------------------------
POSTGRES_USER=swissconnect
POSTGRES_PASSWORD=swissconnect_dev
POSTGRES_DB=swissconnect
DATABASE_URL=postgresql://swissconnect:swissconnect_dev@postgres:5432/swissconnect

# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# -----------------------------------------------------------------------------
# MINIO (S3-kompatibel)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000

# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# -----------------------------------------------------------------------------
# SMTP (Mailcatcher in Dev)
# -----------------------------------------------------------------------------
SMTP_HOST=mailcatcher
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@swiss-connect.ch

# -----------------------------------------------------------------------------
# EXTERNAL APIS
# -----------------------------------------------------------------------------
# Swiss21 API
SWISS21_API_KEY=
SWISS21_API_URL=

# Bexio API
BEXIO_API_KEY=
BEXIO_API_URL=

# Superchat API
SUPERCHAT_API_KEY=
SUPERCHAT_WEBHOOK_SECRET=

# OpenAI (KI-Worker)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
